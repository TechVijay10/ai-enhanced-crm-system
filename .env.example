# ─────────────────────────────────────────────────────────────────────────────
#  AI-Enhanced CRM System — Environment Variables
#  Copy this file to .env and fill in your values before running docker-compose
# ─────────────────────────────────────────────────────────────────────────────

# ── Oracle Database ───────────────────────────────────────────────────────────
DB_USERNAME=system
DB_PASSWORD=oracle

# ── JWT Security ──────────────────────────────────────────────────────────────
# Must be at least 256 bits (32 characters). Change this in production!
JWT_SECRET=crmSecretKey2025SuperSecureKeyForJWTTokenGenerationAtLeast256Bits

# ── CORS ──────────────────────────────────────────────────────────────────────
# The origin the frontend is served from (used by API Gateway)
CORS_ORIGIN=http://localhost:3000

# ── Email (Notification Service) ──────────────────────────────────────────────
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password
